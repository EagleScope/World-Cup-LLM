# ---- Secrets: NEVER commit ----
.env
.env.*
!.env.example
*.key
credentials
aws_credentials

# ---- Collected data (pre-registration TAG policy) ----
# TAG = protocol + frozen scoring + frozen R32 packs ONLY. The tag is created BEFORE
# any forecast/market commit, so the tagged tree contains none of the collected data.
# Live model forecasts AND pre-kickoff market captures are TRACKED and committed in
# per-round commits AFTER the tag (§17 public timestamps) — their value is the
# public timestamped provenance. Only pilot/throwaway logs stay ignored.
data/forecasts/pilot*
data/markets/pilot*
# Pilot evidence kept OUT of the tagged tree (also retained in git history).
data/pilot/_local/
!data/**/.gitkeep

# ---- Python ----
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ipynb_checkpoints/

# ---- OS / editor ----
.DS_Store
*.swp
.idea/
.vscode/

# Demo/scoring artifacts
data/*.png

# throwaway scripts (not part of the study)
scripts/

# Throwaway Elo demo snapshot (real per-match snapshots are committed)
data/packs/elo_snapshots/demo/
